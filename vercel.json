{
  "version": 2,
  "env": {
    "DATABASE_URL": "file:./dev.db"
  },
  "build": {
    "env": {
      "DATABASE_URL": "file:./dev.db"
    }
  },
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
